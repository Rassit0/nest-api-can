// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

enum DocumentType {
  CI
  NIT
}

enum Gender {
  MALE
  FEMALE
}

model Person {
  id             String       @id @default(uuid())
  name           String
  lastName       String       @map("last_name")
  secondLastName String?      @map("second_last_name")
  birthDate      DateTime?    @map("birth_date")
  imageUrl       String?      @map("image_url")
  documentType   DocumentType @map("document_type")
  documentNumber String       @unique @map("document_number")
  phone          String?
  email          String?      @unique
  address        String?
  gender         Gender
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Contactos de la persona
  contacts     PersonContact[] @relation("PersonContacts")
  // Personas que son contactos de la persona
  contactOf    PersonContact[] @relation("ContactPerson")
  players      Player[]
  staff        Staff?
  transactions Transaction[]
  students     Student[]
  user         User?

  @@map("persons")
}

enum ContactRelationship {
  FATHER
  MOTHER
  BROTHER
  SISTER
  SPOUSE
  PARTNER
  UNCLE
  AUNT
  GRANDPARENT
  FRIEND
  TUTOR
  OTHER
}

model PersonContact {
  // Persona a la que se le agrega el contacto
  personId        String
  person          Person @relation("PersonContacts", fields: [personId], references: [id])
  // Persona que es el contacto
  contactPersonId String
  contactPerson   Person @relation("ContactPerson", fields: [contactPersonId], references: [id])

  relationship ContactRelationship

  isPrimaryContact   Boolean @default(false) // Contacto principal
  isEmergencyContact Boolean @default(false) // Contacto de emergencia
  isBillingContact   Boolean @default(false) // Contacto para facturación

  createdAt DateTime @default(now())

  @@id([personId, contactPersonId])
  @@map("person_contacts")
}

model Discipline {
  id         String     @id @default(uuid())
  name       String
  icon       String
  clubs      Club[]
  categories Category[]
  seasons    Season[]
  schools    School[]
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  @@map("disciplines")
}

enum SeasonStatus {
  DRAFT
  ACTIVE
  FINISHED
  CANCELLED
}

model Institution {
  id        String   @id @default(uuid())
  name      String
  imageUrl  String?  @map("image_url")
  address   String
  phone     String?
  email     String?  @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  clubs     Club[]
  seasons   Season[]
  schools   School[]

  @@map("institutions")
}

// ============================
// CLUBS
// ============================
model Club {
  id            String      @id @default(uuid())
  name          String
  shortName     String?     @map("short_name")
  institutionId String      @map("institution_id")
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  disciplineId  String      @map("discipline_id")
  discipline    Discipline  @relation(fields: [disciplineId], references: [id], onDelete: Restrict)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  teams         Team[]

  @@unique([institutionId, disciplineId, name])
  @@map("clubs")
}

// ===================================
// FINAL CLUBS
// ===================================

// ==================================
// INSTALACIONES
// ===================================
model Location {
  id            String  @id @default(uuid())
  name          String
  address       String
  description   String?
  phone         String?
  googleMapsUrl String? @map("google_maps_url")
  latitude      Float?
  longitude     Float?

  // Si es true, es una instalación interna (club, escuela, etc.)
  // Si es false, es una instalación externa
  isInternal Boolean    @default(false) @map("is_internal")
  // Si es true, es una instalación que se puede rentar O ALQUILAR dependiendo si es interna o externa
  isRentable Boolean    @default(false) @map("is_rentable")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  sessions   Session[]
  schedules  Schedule[]
  matches    Match[]

  @@map("locations")
}

// ===================================
// FINAL INSTALACIONES
// ===================================

// =================================
// Categorias
// =================================

model Category {
  id          String  @id @default(uuid())
  name        String
  description String?
  maxAge      Int     @map("max_age")
  minAge      Int     @map("min_age")

  disciplineId String     @map("discipline_id")
  discipline   Discipline @relation(fields: [disciplineId], references: [id], onDelete: Restrict)

  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  teamSeasons   TeamSeason[]
  courseSeasons CourseSeason[]

  @@unique([disciplineId, name])
  @@map("categories")
}

// =================================
// Fin Categorias
// =================================

// =================================
// TEMPORADAS
// =================================

model Season {
  id                  String               @id @default(uuid())
  institutionId       String               @map("institution_id")
  institution         Institution          @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  disciplineId        String               @map("discipline_id")
  discipline          Discipline           @relation(fields: [disciplineId], references: [id], onDelete: Restrict)
  name                String
  description         String?
  startDate           DateTime             @map("start_date")
  endDate             DateTime             @map("end_date")
  teamSeasons         TeamSeason[]
  courseSeasons       CourseSeason[]
  progressEvaluations ProgressEvaluation[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([institutionId, disciplineId, name])
  @@map("seasons")
}

// =================================
// FIN TEMPORADAS
// =================================

enum ProgramGender {
  MALE
  FEMALE
  MIXED
}

// =================================
// Equipos
// =================================
model Team {
  id          String       @id @default(uuid())
  imageUrl    String?      @map("image_url")
  name        String
  shortName   String?      @map("short_name")
  description String?
  clubId      String       @map("club_id")
  club        Club         @relation(fields: [clubId], references: [id], onDelete: Restrict)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  teamSeasons TeamSeason[]

  @@unique([clubId, name])
  @@map("teams")
}

enum StatusTeamSeason {
  DRAFT // por ejemplo para ofertas futuras
  ACTIVE
  FINISHED
  CANCELLED
}

/// Define cómo se estructurará la cobranza de la temporada.
/// MONTHLY_ONLY: Facturación recurrente mes a mes.
/// SINGLE_ONLY: Se cobra un solo monto por toda la temporada (Ej. Campamentos de 6 semanas).
/// BOTH: Permite planes mixtos donde el usuario puede elegir (vía PaymentPlan) si pagar por mes o por toda la temporada adelantada.
enum SeasonBillingType {
  MONTHLY_ONLY // Solo permite mensualidades
  SINGLE_ONLY // Solo permite pago único (Ideal para 6 semanas)
  BOTH // Permite que el usuario elija (usando PaymentPlans)
}

enum BillingFrequency {
  MONTHLY
  WEEKLY
  BIWEEKLY
  SINGLE
}

model TeamSeason {
  id String @id @default(uuid())

  imageUrl    String? @map("image_url")
  description String?

  maxMembers Int @map("max_members")
  minMembers Int @map("min_members")

  minBirthYear Int? @map("min_birth_year")
  maxBirthYear Int? @map("max_birth_year")

  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Restrict)

  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  seasonId String @map("season_id")
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Restrict)

  gender ProgramGender

  billingDay          Int              @map("billing_day") // 1 - 28
  registrationFee     Decimal?         @map("registration_fee") @db.Decimal(10, 2)
  recurringFee        Decimal?         @map("recurring_fee") @db.Decimal(10, 2)
  debtToleranceMonths Int              @default(2) @map("debt_tolerance_months") // meses de tolerancia para no pagar
  lateFeeEnabled      Boolean          @default(false) @map("late_fee_enabled")
  lateFeePerDay       Decimal          @default(0) @map("late_fee_per_day") @db.Decimal(10, 2)
  graceDays           Int              @default(0) @map("grace_days")
  status              StatusTeamSeason @default(DRAFT)

  /// Precio total si el usuario opta por pagar la temporada de un solo golpe (usado en planes SINGLE_ONLY o cuando isSinglePayment es true en BOTH).
  seasonFee Decimal? @map("season_fee") @db.Decimal(10, 2)

  /// Estrategia de facturación aplicable a esta temporada.
  billingType      SeasonBillingType @default(MONTHLY_ONLY) @map("billing_type")
  billingFrequency BillingFrequency  @default(MONTHLY) @map("billing_frequency")

  // Configuraciones de Prorrateo
  prorateFirstRecurringFee Boolean @default(true) @map("prorate_first_recurring_fee")
  prorateLastRecurringFee  Boolean @default(true) @map("prorate_last_recurring_fee")
  prorateRegistrationFee   Boolean @default(false) @map("prorate_registration_fee")
  prorateSeasonFee         Boolean @default(false) @map("prorate_season_fee")

  chargeGenerationDaysBefore Int                @default(7) @map("charge_generation_days_before") // Días antes de generar el cargo
  createdAt                  DateTime           @default(now()) @map("created_at")
  updatedAt                  DateTime           @updatedAt @map("updated_at")
  teamSeasonStaffs           TeamSeasonStaff[]
  paymentPlans               PaymentPlan[]
  playerMemberships          PlayerMembership[]
  sessionTeams               SessionTeam[]
  scheduleTeams              ScheduleTeam[]
  matches                    Match[]

  @@unique([teamId, categoryId, seasonId, gender])
  @@map("team_seasons")
}

model PaymentPlan {
  id                          String        @id @default(uuid())
  teamSeasonId                String?       @map("team_season_id")
  teamSeasons                 TeamSeason?   @relation(fields: [teamSeasonId], references: [id], onDelete: Restrict)
  courseSeasonId              String?       @map("course_season_id")
  courseSeason                CourseSeason? @relation(fields: [courseSeasonId], references: [id], onDelete: Restrict)
  name                        String
  registrationDiscountPercent Decimal       @default(0) @map("registration_discount_percent") @db.Decimal(5, 2)
  recurringDiscountPercent    Decimal       @default(0) @map("recurring_discount_percent") @db.Decimal(5, 2)
  seasonFeeDiscountPercent    Decimal       @default(0) @map("season_fee_discount_percent") @db.Decimal(5, 2)

  isDefault Boolean @default(false) // si es true, es el plan por defecto

  /// Si es true, este plan de pago agrupará toda la temporada en un solo cobro (pago completo de la temporada). Útil para ofrecer descuentos por pago adelantado en temporadas tipo "BOTH".
  isSinglePayment Boolean @default(false) @map("is_single_payment")

  /// Cantidad de cuotas que este plan adelanta/agrupa en un solo recibo. Por defecto 1 (cobro normal). Si es 6, cobra 6 ciclos juntos.
  advanceCycles Int @default(1) @map("advance_cycles")

  /// Porcentaje de descuento aplicado a las cuotas agrupadas/adelantadas. Reemplaza a freeInitialCycles.
  advanceCyclesDiscountPercent Decimal @default(0) @map("advance_cycles_discount_percent") @db.Decimal(5, 2)

  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  playerMemberships  PlayerMembership[]
  studentMemberships StudentMembership[]

  @@map("payment_plans")
}

// =================================
// FIN EQUIPOS
// =================================

// =================================
// JUGADORES Y MEMBRESIAS
// =================================

model Player {
  id                  String               @id @default(uuid())
  personId            String               @unique
  person              Person               @relation(fields: [personId], references: [id])
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  playerMemberships   PlayerMembership[]
  sessionBookings     SessionBooking[]
  matchLineups        MatchLineup[]
  progressEvaluations ProgressEvaluation[]

  @@map("players")
}

enum PlayerMembershipStatus {
  PENDING_ACTIVE // Inscripción creada, esperando pago inicial
  ACTIVE // Habilitado para entrenar y competir
  SUSPENDED // Suspendido por deuda o decisión administrativa
  WITHDRAWN // Se retiró voluntariamente durante la temporada
  FINISHED // Finalizó la temporada
}

model PlayerMembership {
  id           String     @id @default(uuid())
  playerId     String     @map("player_id")
  player       Player     @relation(fields: [playerId], references: [id], onDelete: Restrict)
  teamSeasonId String     @map("team_season_id")
  teamSeason   TeamSeason @relation(fields: [teamSeasonId], references: [id], onDelete: Restrict)

  paymentPlanId String      @map("payment_plan_id")
  paymentPlan   PaymentPlan @relation(fields: [paymentPlanId], references: [id], onDelete: Restrict)

  startedAt DateTime  @map("started_at")
  endedAt   DateTime? @map("ended_at")

  status PlayerMembershipStatus @default(PENDING_ACTIVE)

  notes String?

  // Campo para guardar cual es la siguiente fecha del cargo
  nextRecurringChargeGenerationDate DateTime?

  // Campo para indicar que esta membresia fue migrada desde el sistema antiguo, si es true, no se le generaran cargos anteriores como los iniciales ni mensuales
  isMigrated Boolean @default(false) @map("is_migrated")

  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  membershipDiscounts MembershipDiscount[]
  membershipCharges   MembershipCharge[]

  @@index([nextRecurringChargeGenerationDate])
  @@map("player_membership")
}

enum MembershipDiscountType {
  SCHOLARSHIP // Beca
  SPECIAL_DISCOUNT // Descuento especial
  FINANCIAL_AID // Ayuda económica
  AGREEMENT // Convenio
  EXEMPTION // Exoneración
  OTHER // Otro
}

model MembershipDiscount {
  id                 String           @id @default(uuid())
  playerMembershipId String           @map("player_membership_id")
  playerMembership   PlayerMembership @relation(fields: [playerMembershipId], references: [id], onDelete: Restrict)

  recurringDiscountPercent    Decimal @map("recurring_discount_percent") @db.Decimal(5, 2)
  registrationDiscountPercent Decimal @map("registration_discount_percent") @db.Decimal(5, 2)

  startDate DateTime  @map("start_date")
  endDate   DateTime? @map("end_date")

  type MembershipDiscountType

  reason String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("membership_discounts")
}

enum TypeMembershipCharge {
  REGISTRATION
  RECURRING_FEE
  SEASON_FEE
  LATE_FEE
  MANUAL
}

model MembershipCharge {
  id                 String               @id @default(uuid())
  playerMembershipId String               @map("player_membership_id")
  playerMembership   PlayerMembership     @relation(fields: [playerMembershipId], references: [id], onDelete: Restrict)
  chargeId           String               @map("charge_id")
  charge             Charge               @relation(fields: [chargeId], references: [id], onDelete: Restrict)
  type               TypeMembershipCharge
  // todo: crear un validador para que solo acepte un cargo de tipo matricula

  createdByCron Boolean @default(false) @map("created_by_cron")

  billingYear  Int?
  billingMonth Int?
  billingCycle Int? @map("billing_cycle")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([playerMembershipId, type, billingMonth, billingYear, billingCycle])
  @@map("membership_charges")
}

// =================================
// FIN JUGADORES Y MEMBRESIAS
// =================================

// =================================
// STAFF Y EQUIPOS
// =================================

model Staff {
  id                  String               @id @default(uuid())
  personId            String               @unique @map("person_id")
  person              Person               @relation(fields: [personId], references: [id])
  isActive            Boolean              @default(true) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  teamSeasonStaffs    TeamSeasonStaff[]
  courseSeasonStaffs  CourseSeasonStaff[]
  progressEvaluations ProgressEvaluation[]

  @@map("staff")
}

enum TeamSeasonStaffRole {
  HEAD_COACH
  ASSISTANT_COACH
  ASSISTANT
  VOLUNTEER
  DELEGATE
  OTHER
}

model TeamSeasonStaff {
  id String @id @default(uuid())

  teamSeasonId String @map("team_season_id")
  staffId      String @map("staff_id")

  role       TeamSeasonStaffRole
  // Si el rol es OTHER, se especifica en customRole
  customRole String?             @map("custom_role")

  startedAt DateTime  @map("started_at")
  endedAt   DateTime? @map("ended_at")

  // Si es el encargado del equipo
  isPrimary Boolean @default(false) @map("is_primary")

  notes String?

  teamSeason TeamSeason @relation(fields: [teamSeasonId], references: [id])
  staff      Staff      @relation(fields: [staffId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("team_season_staff")
}

// =================================
// FIN STAFF Y EQUIPOS
// =================================

// =================================
// CARGOS
// =================================
enum StatusCharge {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

model Charge {
  id String @id @default(uuid())

  // Relacion para saber si un cargo es hijo de otro(Ej. Un cargo de mensualidad puede tener recargos por retraso)
  parentChargeId String?
  parentCharge   Charge?  @relation("ChargeParent", fields: [parentChargeId], references: [id])
  childCharges   Charge[] @relation("ChargeParent")

  description   String?
  amount        Decimal      @db.Decimal(10, 2)
  pendingAmount Decimal      @map("pending_amount") @db.Decimal(10, 2)
  dueDate       DateTime     @map("due_date") // Fecha donde vencé el cargo, se puede utilizar para calcular recargos si es de mensualidades
  status        StatusCharge @default(PENDING)

  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  membershipCharges  MembershipCharge[]
  chargeTransactions ChargeTransaction[]
  sessionBooking     SessionBooking?
  studentCharges     StudentCharge[]

  @@map("charges")
}

model ChargeTransaction {
  id            String      @id @default(uuid())
  chargeId      String      @map("charge_id")
  charge        Charge      @relation(fields: [chargeId], references: [id], onDelete: Restrict)
  transactionId String      @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  amountApplied Decimal     @map("amount_applied") @db.Decimal(10, 2)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("charge_transactions")
}

// =================================
// FIN CARGOS
// =================================
// =================================
// TRANSACCIONES
// =================================
enum TransactionType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  QR
  TRANSFER
  CASH
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Transaction {
  id                 String              @id @default(uuid())
  payerPersonId      String?             @map("payer_person_id")
  payerPerson        Person?             @relation(fields: [payerPersonId], references: [id])
  amount             Decimal             @db.Decimal(10, 2)
  transactionDate    DateTime            @map("transaction_date")
  description        String?
  type               TransactionType
  paymentMethod      PaymentMethod       @map("payment_method")
  reference          String?             @map("reference_number")
  notes              String?
  status             TransactionStatus   @default(COMPLETED)
  receiptUrls        String[]            @map("receipt_urls")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  chargeTransactions ChargeTransaction[]

  @@map("transactions")
}

// =================================
// SEGURIDAD (ROLES Y PERMISOS)
// =================================
model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String @map("password_hash")

  personId String? @unique @map("person_id")
  person   Person? @relation(fields: [personId], references: [id], onDelete: Cascade)

  roleId String @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Restrict)

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique // Ej: "ADMIN", "COACH", "PARENT", "PLAYER"
  description String?

  permissions RolePermission[]
  users       User[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  name        String  @unique // Ej: "TAKE_ATTENDANCE", "CREATE_INCIDENT", "VIEW_PAYMENTS"
  module      String // Ej: "SESSIONS", "BILLING", "TEAMS"
  description String?

  roles RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// =================================
// ESCUELAS Y CURSOS
// =================================
model School {
  id            String      @id @default(uuid())
  name          String
  institutionId String      @map("institution_id")
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  disciplineId  String      @map("discipline_id")
  discipline    Discipline  @relation(fields: [disciplineId], references: [id], onDelete: Restrict)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  courses       Course[]

  @@unique([institutionId, disciplineId, name])
  @@map("schools")
}

model Course {
  id            String         @id @default(uuid())
  imageUrl      String?        @map("image_url")
  name          String
  description   String?
  schoolId      String         @map("school_id")
  school        School         @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  courseSeasons CourseSeason[]

  @@unique([schoolId, name])
  @@map("courses")
}

enum StatusCourseSeason {
  DRAFT
  ACTIVE
  FINISHED
  CANCELLED
}

model CourseSeason {
  id          String  @id @default(uuid())
  imageUrl    String? @map("image_url")
  description String?
  maxMembers  Int     @map("max_members")
  minMembers  Int     @map("min_members")

  minBirthYear Int? @map("min_birth_year")
  maxBirthYear Int? @map("max_birth_year")

  courseId   String        @map("course_id")
  course     Course        @relation(fields: [courseId], references: [id], onDelete: Restrict)
  categoryId String        @map("category_id")
  category   Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  seasonId   String        @map("season_id")
  season     Season        @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  gender     ProgramGender

  billingDay                 Int                @map("billing_day")
  registrationFee            Decimal?           @map("registration_fee") @db.Decimal(10, 2)
  recurringFee               Decimal?           @map("recurring_fee") @db.Decimal(10, 2)
  debtToleranceMonths        Int                @default(2) @map("debt_tolerance_months")
  lateFeeEnabled             Boolean            @default(false) @map("late_fee_enabled")
  lateFeePerDay              Decimal            @default(0) @map("late_fee_per_day") @db.Decimal(10, 2)
  graceDays                  Int                @default(0) @map("grace_days")
  status                     StatusCourseSeason @default(DRAFT)
  chargeGenerationDaysBefore Int                @default(7) @map("charge_generation_days_before")

  /// Precio total si el usuario opta por pagar la temporada de un solo golpe (usado en planes SINGLE_ONLY o cuando isSinglePayment es true en BOTH).
  seasonFee Decimal? @map("season_fee") @db.Decimal(10, 2)

  /// Estrategia de facturación aplicable a esta temporada.
  billingType      SeasonBillingType @default(MONTHLY_ONLY) @map("billing_type")
  billingFrequency BillingFrequency  @default(MONTHLY) @map("billing_frequency")

  // Configuraciones de Prorrateo
  prorateFirstRecurringFee Boolean @default(true) @map("prorate_first_recurring_fee")
  prorateLastRecurringFee  Boolean @default(true) @map("prorate_last_recurring_fee")
  prorateRegistrationFee   Boolean @default(false) @map("prorate_registration_fee")
  prorateSeasonFee         Boolean @default(false) @map("prorate_season_fee")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  studentMemberships StudentMembership[]
  paymentPlans       PaymentPlan[]
  courseSeasonStaffs CourseSeasonStaff[]
  sessionCourses     SessionCourse[]
  scheduleCourses    ScheduleCourse[]

  @@unique([courseId, categoryId, seasonId, gender])
  @@map("course_seasons")
}

model CourseSeasonStaff {
  id             String              @id @default(uuid())
  courseSeasonId String              @map("course_season_id")
  courseSeason   CourseSeason        @relation(fields: [courseSeasonId], references: [id], onDelete: Cascade)
  staffId        String              @map("staff_id")
  staff          Staff               @relation(fields: [staffId], references: [id], onDelete: Restrict)
  role           TeamSeasonStaffRole
  customRole     String?             @map("custom_role")
  startedAt      DateTime            @map("started_at")
  endedAt        DateTime?           @map("ended_at")
  isPrimary      Boolean             @default(false) @map("is_primary")
  notes          String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("course_season_staff")
}

// =================================
// ESTUDIANTES Y EVALUACIONES
// =================================
model Student {
  id                  String               @id @default(uuid())
  personId            String               @unique @map("person_id")
  person              Person               @relation(fields: [personId], references: [id])
  isActive            Boolean              @default(true) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  studentMemberships  StudentMembership[]
  sessionBookings     SessionBooking[]
  progressEvaluations ProgressEvaluation[]

  @@map("students")
}

enum StudentMembershipStatus {
  PENDING
  ACTIVE
  SUSPENDED
  WITHDRAWN
  FINISHED
}

model StudentMembership {
  id             String       @id @default(uuid())
  studentId      String       @map("student_id")
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Restrict)
  courseSeasonId String       @map("course_season_id")
  courseSeason   CourseSeason @relation(fields: [courseSeasonId], references: [id], onDelete: Restrict)
  paymentPlanId  String       @map("payment_plan_id")
  paymentPlan    PaymentPlan  @relation(fields: [paymentPlanId], references: [id], onDelete: Restrict)

  startedAt DateTime                @map("started_at")
  endedAt   DateTime?               @map("ended_at")
  status    StudentMembershipStatus @default(PENDING)
  notes     String?

  nextRecurringChargeGenerationDate DateTime?

  // Campo para indicar que esta membresia fue migrada desde el sistema antiguo, si es true, no se le generaran cargos anteriores como los iniciales ni mensuales
  isMigrated Boolean @default(false) @map("is_migrated")

  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  studentDiscounts StudentDiscount[]
  studentCharges   StudentCharge[]

  @@index([nextRecurringChargeGenerationDate])
  @@map("student_memberships")
}

model StudentDiscount {
  id                  String            @id @default(uuid())
  studentMembershipId String            @map("student_membership_id")
  studentMembership   StudentMembership @relation(fields: [studentMembershipId], references: [id], onDelete: Restrict)

  recurringDiscountPercent    Decimal @map("recurring_discount_percent") @db.Decimal(5, 2)
  registrationDiscountPercent Decimal @map("registration_discount_percent") @db.Decimal(5, 2)

  startDate DateTime               @map("start_date")
  endDate   DateTime?              @map("end_date")
  type      MembershipDiscountType
  reason    String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("student_discounts")
}

model StudentCharge {
  id                  String               @id @default(uuid())
  studentMembershipId String               @map("student_membership_id")
  studentMembership   StudentMembership    @relation(fields: [studentMembershipId], references: [id], onDelete: Restrict)
  chargeId            String               @map("charge_id")
  charge              Charge               @relation(fields: [chargeId], references: [id], onDelete: Restrict)
  type                TypeMembershipCharge

  createdByCron Boolean @default(false) @map("created_by_cron")
  billingYear   Int?
  billingMonth  Int?
  billingCycle  Int?    @map("billing_cycle")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([studentMembershipId, type, billingMonth, billingYear, billingCycle])
  @@map("student_charges")
}

model SessionIncident {
  id               String         @id @default(uuid())
  sessionBookingId String         @map("session_booking_id")
  sessionBooking   SessionBooking @relation(fields: [sessionBookingId], references: [id], onDelete: Cascade)

  description String // Detalle de la actitud negativa / mala conducta

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("session_incidents")
}

model ProgressEvaluation {
  id String @id @default(uuid())

  playerId  String?  @map("player_id")
  player    Player?  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  studentId String?  @map("student_id")
  student   Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  evaluatorStaffId String @map("evaluator_staff_id")
  evaluatorStaff   Staff  @relation(fields: [evaluatorStaffId], references: [id], onDelete: Restrict)

  seasonId String @map("season_id")
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Restrict)

  evaluationDate DateTime @map("evaluation_date")

  technicalScore Int? @map("technical_score")
  tacticalScore  Int? @map("tactical_score")
  physicalScore  Int? @map("physical_score")
  behaviorScore  Int? @map("behavior_score")

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("progress_evaluations")
}

// =================================
// ENTRENAMIENTOS Y SESIONES (UNIFICADOS M:N)
// =================================
model Session {
  id          String    @id @default(uuid())
  locationId  String?   @map("location_id")
  location    Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  title       String?
  dateTime    DateTime  @map("date_time")
  durationMin Int       @default(90) @map("duration_min")

  sessionTeams   SessionTeam[]
  sessionCourses SessionCourse[]
  bookings       SessionBooking[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sessions")
}

model SessionTeam {
  sessionId    String
  session      Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  teamSeasonId String     @map("team_season_id")
  teamSeason   TeamSeason @relation(fields: [teamSeasonId], references: [id], onDelete: Restrict)

  @@id([sessionId, teamSeasonId])
  @@map("session_teams")
}

model SessionCourse {
  sessionId      String
  session        Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  courseSeasonId String       @map("course_season_id")
  courseSeason   CourseSeason @relation(fields: [courseSeasonId], references: [id], onDelete: Restrict)

  @@id([sessionId, courseSeasonId])
  @@map("session_courses")
}

model SessionBooking {
  id        String  @id @default(uuid())
  sessionId String  @map("session_id")
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  playerId  String?  @map("player_id")
  player    Player?  @relation(fields: [playerId], references: [id], onDelete: Restrict)
  studentId String?  @map("student_id")
  student   Student? @relation(fields: [studentId], references: [id], onDelete: Restrict)

  isExternal Boolean @default(false) @map("is_external")
  attended   Boolean @default(false)

  chargeId String? @unique @map("charge_id")
  charge   Charge? @relation(fields: [chargeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  incidents SessionIncident[]

  @@unique([sessionId, playerId])
  @@unique([sessionId, studentId])
  @@map("session_bookings")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model Schedule {
  id         String    @id @default(uuid())
  locationId String?   @map("location_id")
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  dayOfWeek  DayOfWeek @map("day_of_week")
  startTime  String    @map("start_time")
  endTime    String    @map("end_time")

  scheduleTeams   ScheduleTeam[]
  scheduleCourses ScheduleCourse[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("schedules")
}

model ScheduleTeam {
  scheduleId   String
  schedule     Schedule   @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  teamSeasonId String     @map("team_season_id")
  teamSeason   TeamSeason @relation(fields: [teamSeasonId], references: [id], onDelete: Restrict)

  @@id([scheduleId, teamSeasonId])
  @@map("schedule_teams")
}

model ScheduleCourse {
  scheduleId     String
  schedule       Schedule     @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  courseSeasonId String       @map("course_season_id")
  courseSeason   CourseSeason @relation(fields: [courseSeasonId], references: [id], onDelete: Restrict)

  @@id([scheduleId, courseSeasonId])
  @@map("schedule_courses")
}

// =================================
// COMPETENCIAS Y PARTIDOS
// =================================
enum MatchType {
  FRIENDLY
  LEAGUE
  TOURNAMENT
  CUP
}

enum MatchResult {
  WIN
  LOSS
  DRAW
  PENDING
}

model Match {
  id           String     @id @default(uuid())
  teamSeasonId String     @map("team_season_id")
  teamSeason   TeamSeason @relation(fields: [teamSeasonId], references: [id], onDelete: Restrict)
  locationId   String?    @map("location_id")
  location     Location?  @relation(fields: [locationId], references: [id], onDelete: SetNull)

  opponentName String    @map("opponent_name")
  matchDate    DateTime  @map("match_date")
  type         MatchType @default(LEAGUE)

  ourScore   Int?        @map("our_score")
  theirScore Int?        @map("their_score")
  result     MatchResult @default(PENDING)

  lineups MatchLineup[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("matches")
}

model MatchLineup {
  id       String @id @default(uuid())
  matchId  String @map("match_id")
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId String @map("player_id")
  player   Player @relation(fields: [playerId], references: [id], onDelete: Restrict)

  minutesPlayed Int     @default(0) @map("minutes_played")
  goals         Int     @default(0)
  assists       Int     @default(0)
  yellowCards   Int     @default(0) @map("yellow_cards")
  redCards      Int     @default(0) @map("red_cards")
  isStarter     Boolean @default(false) @map("is_starter")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([matchId, playerId])
  @@map("match_lineups")
}
