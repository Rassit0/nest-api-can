  updatedCourseSeasonPauses         CourseSeasonPause[]         @relation("UpdatedBy")
  createdCourseSeasonBillingConfigs CourseSeasonBillingConfig[] @relation("CreatedBy")
  updatedCourseSeasonBillingConfigs CourseSeasonBillingConfig[] @relation("UpdatedBy")
