// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum DocumentType {
  CI
  NIT
}

enum Gender {
  MALE
  FEMALE
}

model Person {
  id             String       @id @default(uuid())
  name           String
  lastName       String       @map("last_name")
  secondLastName String?      @map("second_last_name")
  birthDate      DateTime?    @map("birth_date")
  imageUrl       String?      @map("image_url")
  documentType   DocumentType @map("document_type")
  documentNumber String       @map("document_number")
  phone          String?
  email          String?      @unique
  address        String?
  gender         Gender
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Contactos de la persona
  contacts  PersonContact[] @relation("PersonContacts")
  // Personas que son contactos de la persona
  contactOf PersonContact[] @relation("ContactPerson")
  players   Player[]
  students  Student[]

  @@map("persons")
}

enum ContactRelationship {
  FATHER
  MOTHER
  BROTHER
  SISTER
  SPOUSE
  PARTNER
  UNCLE
  AUNT
  GRANDPARENT
  FRIEND
  TUTOR
  OTHER
}

model PersonContact {
  // Persona a la que se le agrega el contacto
  personId        String
  person          Person @relation("PersonContacts", fields: [personId], references: [id])
  // Persona que es el contacto
  contactPersonId String
  contactPerson   Person @relation("ContactPerson", fields: [contactPersonId], references: [id])

  relationship ContactRelationship

  isPrimaryContact   Boolean @default(false) // Contacto principal
  isEmergencyContact Boolean @default(false) // Contacto de emergencia
  isBillingContact   Boolean @default(false) // Contacto para facturación

  createdAt DateTime @default(now())

  @@id([personId, contactPersonId])
  @@map("person_contacts")
}

model Player {
  id              String           @id @default(uuid())
  personId        String           @unique
  person          Person           @relation(fields: [personId], references: [id])
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  teamMemberships TeamMembership[]
  playerPasses    PlayerPass[]

  @@map("players")
}

model Student {
  id                String             @id @default(uuid())
  personId          String             @unique
  person            Person             @relation(fields: [personId], references: [id])
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  courseEnrollments CourseEnrollment[]

  @@map("students")
}

model Discipline {
  id        String   @id @default(uuid())
  name      String
  icon      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clubs     Club[]
  schools   School[]

  @@map("disciplines")
}

enum SeasonStatus {
  DRAFT
  ACTIVE
  FINISHED
  CANCELLED
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  imageUrl  String?  @map("image_url")
  address   String
  phone     String?
  email     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clubs     Club[]
  schools   School[]

  @@map("organizations")
}

// ============================
// CLUBS
// ============================
model Club {
  id             String       @id @default(uuid())
  name           String
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  disciplineId   String       @map("discipline_id")
  discipline     Discipline   @relation(fields: [disciplineId], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  teams          Team[]

  @@unique([organizationId, disciplineId, name])
  @@map("clubs")
}

// ===================================
// FINAL CLUBS
// ===================================

// ==================================
// INSTALACIONES
// ===================================
model Location {
  id            String  @id @default(uuid())
  name          String
  address       String
  description   String?
  phone         String?
  googleMapsUrl String? @map("google_maps_url")
  latitude      Float?
  longitude     Float?

  // Si es true, es una instalación interna (club, escuela, etc.)
  // Si es false, es una instalación externa
  isInternal Boolean    @default(false) @map("is_internal")
  // Si es true, es una instalación que se puede rentar O ALQUILAR dependiendo si es interna o externa
  isRentable Boolean    @default(false) @map("is_rentable")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  activities Activity[]

  @@map("locations")
}

// =================================
// ACTIVIDADES
// ==================================
enum ActivityType {
  TRAINING
  MATCH
  CLASS
  EVENT
  RENTAL
}

model Activity {
  id                     String                 @id @default(uuid())
  title                  String
  description            String
  startsAt               DateTime               @map("starts_at")
  endsAt                 DateTime               @map("ends_at")
  locationId             String                 @map("location_id")
  location               Location               @relation(fields: [locationId], references: [id], onDelete: Restrict)
  type                   ActivityType           @default(TRAINING)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  teamSeasonActivities   TeamSeasonActivity[]
  courseSeasonActivities CourseSeasonActivity[]

  @@map("activities")
}

// ===================================
// FINAL ACTIVITIES
// ===================================

enum ProgramGender {
  MALE
  FEMALE
  MIXED
}

enum ProgramStatus {
  ACTIVE // activo
  SUSPENDED // suspendido
  WITHDRAWN // retirado
}

// =================================
// Equipos
// =================================
model Team {
  id          String        @id @default(uuid())
  imageUrl    String?       @map("image_url")
  name        String
  clubId      String        @map("club_id")
  club        Club          @relation(fields: [clubId], references: [id], onDelete: Restrict)
  gender      ProgramGender
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  teamSeasons TeamSeason[]

  // Pases donde este equipo es el actual
  currentPlayerPasses PlayerPass[] @relation("CurrentTeamPasses")

  // Pases donde este equipo era el anterior
  previousPlayerPasses PlayerPass[] @relation("PreviousTeamPasses")

  @@map("teams")
}

model TeamSeason {
  id String @id @default(uuid())

  // Datos del periodo de inscripcion
  name      String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")

  // Datos del equipo
  teamId                     String       @map("team_id")
  team                       Team         @relation(fields: [teamId], references: [id], onDelete: Restrict)
  maxMembers                 Int          @map("max_members")
  minMembers                 Int          @map("min_members")
  maxYear                    Int          @map("max_year")
  minYear                    Int          @map("min_year")
  monthlyFee                 Decimal      @map("monthly_fee") @db.Decimal(10, 2)
  registrationFee            Decimal      @map("registration_fee") @db.Decimal(10, 2)
  fullPaymentDiscountPercent Decimal      @map("full_payment_discount_percent") @db.Decimal(5, 2)
  // Recargos por mora habilitados
  lateFeeEnabled             Boolean      @default(false) @map("late_fee_enabled")
  // Recargo por dia de atraso
  lateFeePerDay              Decimal      @default(0) @map("late_fee_per_day") @db.Decimal(10, 2)
  // Días de gracia para el pago de la mensualidad. Osea días de tolerancia
  graceDays                  Int          @default(0) @map("grace_days")
  // Meses de atraso para la suspensión del servicio
  suspensionAfterMonthsDue   Int          @default(2) @map("suspension_after_months_due")
  status                     SeasonStatus @default(DRAFT)
  statusNotes                String?      @map("status_notes")

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  teamMemberships      TeamMembership[]
  teamSeasonActivities TeamSeasonActivity[]
  teamSeasonExtensions TeamSeasonExtension[]

  @@map("team_seasons")
}

// Si se realiza una extension aqui se guarda el historial,y se edita la fecha final de la temporada
model TeamSeasonExtension {
  id String @id @default(uuid())

  teamSeasonId String     @map("team_season_id")
  teamSeason   TeamSeason @relation(fields: [teamSeasonId], references: [id], onDelete: Restrict)

  previousEndDate DateTime @map("previous_end_date")
  newEndDate      DateTime @map("new_end_date")

  reason String

  createdAt DateTime @default(now())

  @@map("team_season_extensions")
}

model TeamSeasonActivity {
  activityId   String     @map("activity_id")
  activity     Activity   @relation(fields: [activityId], references: [id], onDelete: Restrict)
  teamSeasonId String     @map("team_offering_id")
  teamSeason   TeamSeason @relation(fields: [teamSeasonId], references: [id], onDelete: Restrict)

  @@id([activityId, teamSeasonId])
  @@map("team_offering_activities")
}

model TeamMembership {
  id           String     @id @default(uuid())
  playerId     String     @map("player_id")
  player       Player     @relation(fields: [playerId], references: [id], onDelete: Restrict)
  teamSeasonId String     @map("team_offering_id")
  teamSeason   TeamSeason @relation(fields: [teamSeasonId], references: [id], onDelete: Restrict)
  startedAt    DateTime   @map("started_at")
  endedAt      DateTime?  @map("ended_at")

  // Dia del mes en que se genera la factura, para poder generar para el otro mes
  billingDayOfMonth Int @map("billing_day_of_month")

  status ProgramStatus @default(ACTIVE)

  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  teamMembershipDiscounts TeamMembershipDiscount[]

  @@map("team_memberships")
}

model TeamMembershipDiscount {
  id                          String         @id @default(uuid())
  teamMembershipId            String         @map("team_membership_id")
  teamMembership              TeamMembership @relation(fields: [teamMembershipId], references: [id], onDelete: Restrict)
  monthlyDiscountPercent      Decimal        @map("monthly_discount_percent") @db.Decimal(5, 2)
  registrationDiscountPercent Decimal        @map("registration_discount_percent") @db.Decimal(5, 2)
  startDate                   DateTime       @map("start_date")
  endDate                     DateTime?      @map("end_date")

  reason String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("team_membership_discounts")
}

enum PassOriginType {
  INTERNAL
  EXTERNAL
  FREE_AGENT
}

enum PlayerPassStatus {
  PENDING
  ACTIVE
  INACTIVE
  REJECTED
}

enum PreviousTeamSource {
  SYSTEM
  EXTERNAL
  FREE_AGENT
}

model PlayerPass {
  id String @id @default(uuid())

  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Restrict)

  currentTeamId String @map("current_team_id")
  currentTeam   Team   @relation("CurrentTeamPasses", fields: [currentTeamId], references: [id], onDelete: Restrict)

  // Si es interno, se guarda el id del equipo anterior
  previousTeamId           String? @map("previous_team_id")
  previousTeam             Team?   @relation("PreviousTeamPasses", fields: [previousTeamId], references: [id], onDelete: Restrict)
  // Nombre del equipo anterior si es externo
  externalPreviousTeamName String? @map("external_previous_team_name")

  originType         PassOriginType     @map("origin_type")
  // Si el origen es libre, el equipo anterior es libre por defecto
  // Ahora si origen es externo, se debe indicar si es SYSTEM o EXTERNAL para indicar si el equipo previo es fuera de la organizacion
  // Si es Interno, por defecto indica en SYSTEM porque se supone que existe en el sistema,
  previousTeamSource PreviousTeamSource @map("previous_team_source")
  status             PlayerPassStatus   @default(PENDING) @map("status")

  // Si se cierra el pase indicar a que equipo se va para mantener el historial
  externalNextTeamName String? @map("external_next_team_name")

  startDate DateTime  @map("start_date")
  endDate   DateTime? @map("end_date")

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("player_passes")
}

// ================================================
// FIN DE EQUIPOS
// ================================================

// ===============================================
// Escuelas
// ===============================================

model School {
  id             String       @id @default(uuid())
  name           String
  imageUrl       String?      @map("image_url")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  disciplineId   String       @map("discipline_id")
  discipline     Discipline   @relation(fields: [disciplineId], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  courses        Course[]

  @@map("schools")
}

model Course {
  id           String         @id @default(uuid())
  schoolId     String         @map("school_id")
  school       School         @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  name         String
  gender       ProgramGender
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  courseSeason CourseSeason[]

  @@map("courses")
}

model CourseSeason {
  id String @id @default(uuid())

  // Datos del periodo de inscripcion
  name      String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")

  // Datos del curso
  courseId                   String  @map("course_id")
  course                     Course  @relation(fields: [courseId], references: [id], onDelete: Restrict)
  maxMembers                 Int     @map("max_members")
  minMembers                 Int     @map("min_members")
  monthlyFee                 Decimal @map("monthly_fee") @db.Decimal(10, 2)
  registrationFee            Decimal @map("registration_fee") @db.Decimal(10, 2)
  fullPaymentDiscountPercent Decimal @map("full_payment_discount_percent") @db.Decimal(5, 2)
  maxYear                    Int     @map("max_year")
  minYear                    Int     @map("min_year")
  lateFeeEnabled             Boolean @default(false) @map("late_fee_enabled")
  // Recargo por dia de atraso
  lateFeePerDay              Decimal @default(0) @map("late_fee_per_day") @db.Decimal(10, 2)
  // Días de gracia para el pago de la mensualidad. Osea días de tolerancia
  graceDays                  Int     @default(0) @map("grace_days")
  // Meses de atraso para la suspensión del servicio
  suspensionAfterMonthsDue   Int     @default(2) @map("suspension_after_months_due")

  status      SeasonStatus @default(DRAFT)
  statusNotes String?      @map("status_notes")

  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  courseEnrollments      CourseEnrollment[]
  courseSeasonActivities CourseSeasonActivity[]

  @@map("course_seasons")
}

model CourseSeasonActivity {
  activityId     String       @map("activity_id")
  activity       Activity     @relation(fields: [activityId], references: [id], onDelete: Restrict)
  courseSeasonId String       @map("course_offering_id")
  courseSeason   CourseSeason @relation(fields: [courseSeasonId], references: [id], onDelete: Restrict)

  @@id([activityId, courseSeasonId])
  @@map("course_offering_activities")
}

model CourseEnrollment {
  id                String        @id @default(uuid())
  studentId         String        @map("student_id")
  student           Student       @relation(fields: [studentId], references: [id], onDelete: Restrict)
  courseSeasonId    String        @map("course_offering_id")
  courseSeason      CourseSeason  @relation(fields: [courseSeasonId], references: [id], onDelete: Restrict)
  // Dia del mes en que se genera la factura, para poder generar para el otro mes
  billingDayOfMonth Int           @map("billing_day_of_month")
  startedAt         DateTime      @map("started_at")
  endedAt           DateTime?     @map("ended_at")
  status            ProgramStatus @default(ACTIVE)

  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  courseEnrollmentDiscounts CourseEnrollmentDiscount[]

  @@map("course_enrollments")
}

model CourseEnrollmentDiscount {
  id                          String           @id @default(uuid())
  courseEnrollmentId          String           @map("course_enrollment_id")
  courseEnrollment            CourseEnrollment @relation(fields: [courseEnrollmentId], references: [id], onDelete: Restrict)
  monthlyDiscountPercent      Decimal          @map("monthly_discount_percent") @db.Decimal(5, 2)
  registrationDiscountPercent Decimal          @map("registration_discount_percent") @db.Decimal(5, 2)
  startDate                   DateTime         @map("start_date")
  endDate                     DateTime?        @map("end_date")

  reason String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("course_enrollment_discounts")
}

// ==========================================
// FIN DE ESCUELAS
// ==========================================
