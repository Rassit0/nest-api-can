// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UniformSize {
  XS
  S
  M
  L
  XL
  XXL
  XXXL
}

// --- MODELOS DE NEGOCIO ---

model Person {
  id             Int          @id @default(autoincrement())
  ci             String       @unique
  name           String
  lastName       String       @map("last_name")
  surName        String?      @map("sur_name")
  email          String?      @unique
  phone          String?
  phoneEmergency String?      @map("phone_emergency")
  address        String?
  birthDate      DateTime?    @map("birth_date")
  standardSize   UniformSize? @map("standard_size") // La talla real de la persona
  imageUrl       String?      @map("image_url") // Para guardar una foto de perfil (opcional)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  employeeProfiles EmployeeProfile[] // Puede tener múltiples perfiles de empleado en diferentes cargos, pero solo uno activo a la vez
  teacherProfiles  TeacherProfile[] // Puede tener múltiples perfiles de profesor en diferentes disciplinas
  studentProfiles  StudentProfile[] // Puede tener múltiples perfiles de estudiante en diferentes disciplinas
  // contracts        Contract[]
  // transactions     Transaction[]
  enrollments      Enrollment[]
  playerProfiles   PlayerProfile[] // Puede tener múltiples perfiles de jugador en diferentes disciplinas
  user             User?

  // Personas a las que esta persona tutela
  wards       TutorRelation[] @relation("Tutors")
  // Personas que son tutores de esta persona
  tutors      TutorRelation[] @relation("Wards")
  teamMembers TeamMember[]
  attendances Attendance[]

  @@index([lastName, name])
  @@map("persons")
}

model TutorRelation {
  id Int @id @default(autoincrement())

  // El estudiante o niño (el tutelado)
  wardId Int    @map("ward_id")
  ward   Person @relation("Wards", fields: [wardId], references: [id])

  // El tutor
  tutorId Int    @map("tutor_id")
  tutor   Person @relation("Tutors", fields: [tutorId], references: [id])

  // Extra: Puedes añadir el tipo de relación (Madre, Padre, Abuelo)
  relationship String @default("Apoderado")

  @@unique([wardId, tutorId]) // Evita duplicados
  @@map("tutor_relations")
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  password  String
  personId  Int       @unique
  person    Person    @relation(fields: [personId], references: [id], onDelete: Restrict)
  // transactions Transaction[]
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")

  @@map("users")
}

// --- PERFILES ESPECÍFICOS (Multicargo) ---

model EmployeeProfile {
  id       Int      @id @default(autoincrement())
  position String // Cargo que desempeña (Ej: "Entrenador", "Administrador")
  hireDate DateTime @map("hire_date") // Fecha de contratacion
  isActive Boolean  @default(true) @map("is_active") // Permite saber cuál es su cargo actual

  personId Int    @map("person_id") // SIN @unique: Permite varios cargos
  person   Person @relation(fields: [personId], references: [id], onDelete: Restrict)

  @@map("employee_profiles")
}

model Discipline {
  id   Int     @id @default(autoincrement())
  name String  @unique // "Voley", "Basquet", "Raqueta Frontón"
  icon String? // Opcional: Para guardar un emoji o link a icono

  studentProfiles     StudentProfile[] // Nueva relación
  teacherProfiles     TeacherProfile[]
  playerProfiles      PlayerProfile[]
  teams               Team[]
  activityDisciplines ActivityDiscipline[]

  @@map("disciplines")
}

model TeacherProfile {
  id        Int      @id @default(autoincrement())
  bio       String? // Breve descripción o especialización del profesor
  // Auditoría
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  isActive Boolean @default(true) @map("is_active")

  deletedAt DateTime? @map("deleted_at")

  // Relaciones
  disciplineId Int        @map("discipline_id")
  discipline   Discipline @relation(fields: [disciplineId], references: [id], onDelete: Restrict)

  person   Person @relation(fields: [personId], references: [id])
  personId Int

  @@unique([personId, disciplineId])
  @@map("teacher_profiles")
}

enum GradeLevel {
  BEGINNER // Principiante
  INTERMEDIATE // Intermedio
  ADVANCED // Avanzado
}

model StudentProfile {
  id          Int        @id @default(autoincrement())
  gradeLevel  GradeLevel @map("grade_level") // Ej: "Intermedio", "Avanzado"
  scholarship Decimal    @default(0)

  // Auditoría
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")

  personId     Int        @map("person_id")
  person       Person     @relation(fields: [personId], references: [id], onDelete: Restrict)
  disciplineId Int        @map("discipline_id")
  discipline   Discipline @relation(fields: [disciplineId], references: [id], onDelete: Restrict)

  @@unique([personId, disciplineId]) // Una persona puede ser estudiante en múltiples disciplinas
  @@map("student_profiles")
}

model PlayerProfile {
  id             Int     @id @default(autoincrement())
  personId       Int     @map("person_id")
  person         Person  @relation(fields: [personId], references: [id], onDelete: Restrict)
  isActive       Boolean @default(true) @map("is_active")
  registerNumber String? @map("register_number") // Número de registro deportivo (opcional)

  //Relaciones
  disciplineId Int        @map("discipline_id")
  discipline   Discipline @relation(fields: [disciplineId], references: [id], onDelete: Restrict)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([personId, disciplineId])
  @@map("player_profiles")
}

model Team {
  id Int @id @default(autoincrement())

  name String

  disciplineId Int
  categoryId   Int // 👈 CLAVE

  discipline Discipline @relation(fields: [disciplineId], references: [id])
  category   Category   @relation(fields: [categoryId], references: [id])

  members                 TeamMember[]
  enrollmentPlayerDetails EnrollmentPlayerDetail[]
  homeMatches             MatchDetail[]            @relation("HomeTeam")
  awayMatches             MatchDetail[]            @relation("AwayTeam")

  @@unique([name, disciplineId, categoryId])
}

model TeamMember {
  id Int @id @default(autoincrement())

  teamId   Int
  personId Int

  isActive Boolean  @default(true)
  joinedAt DateTime @default(now())

  team   Team   @relation(fields: [teamId], references: [id])
  person Person @relation(fields: [personId], references: [id])

  @@unique([teamId, personId])
}

enum ActivityType {
  TRAINING // Entrenamientos (recurrentes)
  MATCH // Partidos (evento puntual deportivo)
  TOURNAMENT // Campeonatos / ligas
  EDUCATIONAL // Escuelas / cursos
  EVENT // Eventos sociales o generales
}

enum MatchType {
  LEAGUE // Partido de liga o campeonato
  FRIENDLY // Partido amistoso
  TOURNAMENT // Partido de torneo específico
}

enum MatchStatus {
  SCHEDULED // Programado
  IN_PROGRESS // En juego
  FINISHED // Finalizado
  CANCELED // Cancelado
  POSTPONED // Postergado
}

model MatchDetail {
  id Int @id @default(autoincrement())

  activityId Int

  homeTeamId Int
  awayTeamId Int

  scoreHome Int?
  scoreAway Int?
  matchType MatchType

  status MatchStatus // programado, en juego, finalizado

  homeTeam Team @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam Team @relation("AwayTeam", fields: [awayTeamId], references: [id])

  activity Activity @relation(fields: [activityId], references: [id])
}

// --- ACTIVIDAD (El contenedor maestro) ---
model Activity {
  id       Int          @id @default(autoincrement())
  name     String // "Entrenamiento Voley 2026", "Curso React Inicial"
  type     ActivityType
  location String? // "Cancha Principal", "Sala de Computación"

  // Fechas de vigencia de la actividad (Temporada o curso)
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")

  // PRECIO TOTAL (Obligatorio)
  // Si no hay precio, la base de datos no deja insertar la actividad
  // Precio total para eventos (puede ser 0 si es gratuito)
  totalPrice Decimal @map("total_price") @db.Decimal(10, 2)

  // Si tiene pago mensual y numero de cuotas
  monthlyPrice Decimal? @map("monthly_price") @db.Decimal(10, 2) // Precio de la mensualidad (si aplica)
  installments Int? // Cuántas cuotas (ej: 4 meses)

  // 👇 recursividad ( ejemplo: cuando es un partido que pertenece a una actividad principal como campeonatos, etc)
  parentId Int?
  parent   Activity?  @relation("ActivityHierarchy", fields: [parentId], references: [id])
  children Activity[] @relation("ActivityHierarchy")

  // Auditoría
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")

  // Relaciones
  schedules           Schedule[] // Reglas de horario
  enrollments         Enrollment[]
  attendances         Attendance[]
  activityCategories  ActivityCategory[]
  activityDisciplines ActivityDiscipline[]
  matchDetails        MatchDetail[]

  @@map("activities")
}

model ActivityDiscipline {
  id Int @id @default(autoincrement())

  activityId   Int
  disciplineId Int

  activity   Activity   @relation(fields: [activityId], references: [id])
  discipline Discipline @relation(fields: [disciplineId], references: [id])

  @@unique([activityId, disciplineId])
}

enum GenderCategory {
  MALE
  FEMALE
  MIXED
}

model Category {
  id          Int            @id @default(autoincrement())
  name        String         @unique // "Sub-17", "Sénior"
  slug        String         @unique // "sub-17", "senior"
  description String?        @db.Text
  minAge      Int
  maxAge      Int
  gender      GenderCategory
  isActive    Boolean        @default(true)

  // Auditoría
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  teams              Team[]
  activityCategories ActivityCategory[]

  @@map("categories")
}

model ActivityCategory {
  id Int @id @default(autoincrement())

  activityId Int
  categoryId Int

  activity Activity @relation(fields: [activityId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([activityId, categoryId])
}

// --- HORARIO RECURRENTE (Reglas de tiempo) ---
model Schedule {
  id         Int       @id @default(autoincrement())
  activityId Int       @map("activity_id")
  isActive   Boolean   @default(true) @map("is_active")
  deletedAt  DateTime? @map("deleted_at")

  // Días de la semana (0=Domingo, 1=Lunes, ..., 6=Sábado)
  dayOfWeek Int    @map("day_of_week")
  startTime String // "18:00"
  endTime   String // "20:00"

  activity    Activity     @relation(fields: [activityId], references: [id], onDelete: Restrict)
  attendances Attendance[]

  @@unique([activityId, dayOfWeek, startTime])
  @@index([activityId])
  @@map("schedules")
}

enum EnrollmentRole {
  PLAYER
  STUDENT
  TEACHER
}

model Enrollment {
  id         Int            @id @default(autoincrement())
  personId   Int            @map("person_id")
  activityId Int            @map("activity_id")
  role       EnrollmentRole // PLAYER, STUDENT, TEACHER
  isActive   Boolean        @default(true) @map("is_active")

  person   Person   @relation(fields: [personId], references: [id], onDelete: Restrict)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Restrict)

  // Extensiones (Tablas hijas)
  playerDetail  EnrollmentPlayerDetail?
  studentDetail EnrollmentStudentDetail?
  // transactions  Transaction[]

  @@unique([personId, activityId, role])
  @@index([activityId])
  @@index([personId])
  @@map("enrollments")
}

// Si el Enrollment es de un deportista
model EnrollmentPlayerDetail {
  id Int @id @default(autoincrement())

  enrollmentId Int     @unique
  position     String
  isGuest      Boolean @default(false) // Para saber si es un jugador invitado (que no pertenece a un equipo)refuerzo

  teamId Int?
  team   Team? @relation(fields: [teamId], references: [id])

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
}

// Si el Enrollment es de un alumno
model EnrollmentStudentDetail {
  id           Int        @id @default(autoincrement())
  enrollmentId Int        @unique @map("enrollment_id")
  gradeLevel   GradeLevel @map("grade_level") // Ej: "Avanzado"
  scholarship  Decimal    @default(0) @map("scholarship")

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)

  @@map("enrollment_student_details")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  JUSTIFIED
}

model Attendance {
  id Int @id @default(autoincrement())

  personId   Int
  activityId Int
  scheduleId Int? // 👈 CLAVE

  date   DateTime
  status AttendanceStatus

  person   Person    @relation(fields: [personId], references: [id])
  activity Activity  @relation(fields: [activityId], references: [id])
  schedule Schedule? @relation(fields: [scheduleId], references: [id])

  @@unique([personId, activityId, date, scheduleId])
}

