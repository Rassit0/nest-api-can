  updatedStudentMemberships         StudentMembership[]         @relation("UpdatedBy")
  createdStudentMembershipHistories StudentMembershipHistory[]  @relation("CreatedBy")
  updatedStudentMembershipHistories StudentMembershipHistory[]  @relation("UpdatedBy")
  createdStudentMembershipPauses    StudentMembershipPause[]    @relation("CreatedBy")
  updatedStudentMembershipPauses    StudentMembershipPause[]    @relation("UpdatedBy")
  createdStudentDiscounts           StudentDiscount[]           @relation("CreatedBy")
  updatedStudentDiscounts           StudentDiscount[]           @relation("UpdatedBy")
  createdStudentCharges             StudentCharge[]             @relation("CreatedBy")
