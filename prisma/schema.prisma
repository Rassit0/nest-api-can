// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

enum DocumentType {
  CI
  NIT
}

enum Gender {
  MALE
  FEMALE
}

model Person {
  id             String       @id @default(uuid())
  name           String
  lastName       String       @map("last_name")
  secondLastName String?      @map("second_last_name")
  birthDate      DateTime?    @map("birth_date")
  imageUrl       String?      @map("image_url")
  documentType   DocumentType @map("document_type")
  documentNumber String       @unique @map("document_number")
  phone          String?
  email          String?      @unique
  address        String?
  gender         Gender
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Contactos de la persona
  contacts  PersonContact[] @relation("PersonContacts")
  // Personas que son contactos de la persona
  contactOf PersonContact[] @relation("ContactPerson")
  players   Player[]
  staff     Staff?

  @@map("persons")
}

enum ContactRelationship {
  FATHER
  MOTHER
  BROTHER
  SISTER
  SPOUSE
  PARTNER
  UNCLE
  AUNT
  GRANDPARENT
  FRIEND
  TUTOR
  OTHER
}

model PersonContact {
  // Persona a la que se le agrega el contacto
  personId        String
  person          Person @relation("PersonContacts", fields: [personId], references: [id])
  // Persona que es el contacto
  contactPersonId String
  contactPerson   Person @relation("ContactPerson", fields: [contactPersonId], references: [id])

  relationship ContactRelationship

  isPrimaryContact   Boolean @default(false) // Contacto principal
  isEmergencyContact Boolean @default(false) // Contacto de emergencia
  isBillingContact   Boolean @default(false) // Contacto para facturación

  createdAt DateTime @default(now())

  @@id([personId, contactPersonId])
  @@map("person_contacts")
}

model Discipline {
  id         String     @id @default(uuid())
  name       String
  icon       String
  clubs      Club[]
  categories Category[]
  seasons    Season[]
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  @@map("disciplines")
}

enum SeasonStatus {
  DRAFT
  ACTIVE
  FINISHED
  CANCELLED
}

model Institution {
  id        String   @id @default(uuid())
  name      String
  imageUrl  String?  @map("image_url")
  address   String
  phone     String?
  email     String?  @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  clubs     Club[]
  seasons   Season[]

  @@map("institutions")
}

// ============================
// CLUBS
// ============================
model Club {
  id            String      @id @default(uuid())
  name          String
  institutionId String      @map("institution_id")
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  disciplineId  String      @map("discipline_id")
  discipline    Discipline  @relation(fields: [disciplineId], references: [id], onDelete: Restrict)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  teams         Team[]

  @@unique([institutionId, disciplineId, name])
  @@map("clubs")
}

// ===================================
// FINAL CLUBS
// ===================================

// ==================================
// INSTALACIONES
// ===================================
model Location {
  id            String  @id @default(uuid())
  name          String
  address       String
  description   String?
  phone         String?
  googleMapsUrl String? @map("google_maps_url")
  latitude      Float?
  longitude     Float?

  // Si es true, es una instalación interna (club, escuela, etc.)
  // Si es false, es una instalación externa
  isInternal Boolean  @default(false) @map("is_internal")
  // Si es true, es una instalación que se puede rentar O ALQUILAR dependiendo si es interna o externa
  isRentable Boolean  @default(false) @map("is_rentable")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("locations")
}

// ===================================
// FINAL INSTALACIONES
// ===================================

// =================================
// Categorias
// =================================

model Category {
  id          String  @id @default(uuid())
  name        String
  description String?
  maxAge      Int     @map("max_age")
  minAge      Int     @map("min_age")

  disciplineId String     @map("discipline_id")
  discipline   Discipline @relation(fields: [disciplineId], references: [id], onDelete: Restrict)

  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  teamSeasons TeamSeason[]

  @@unique([disciplineId, name])
  @@map("categories")
}

// =================================
// Fin Categorias
// =================================

// =================================
// TEMPORADAS
// =================================

model Season {
  id            String       @id @default(uuid())
  institutionId String       @map("institution_id")
  institution   Institution  @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  disciplineId  String       @map("discipline_id")
  discipline    Discipline   @relation(fields: [disciplineId], references: [id], onDelete: Restrict)
  name          String
  description   String?
  startDate     DateTime     @map("start_date")
  endDate       DateTime     @map("end_date")
  teamSeasons   TeamSeason[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([institutionId, disciplineId, name])
  @@map("seasons")
}

// =================================
// FIN TEMPORADAS
// =================================

enum ProgramGender {
  MALE
  FEMALE
  MIXED
}

// =================================
// Equipos
// =================================
model Team {
  id          String       @id @default(uuid())
  imageUrl    String?      @map("image_url")
  name        String
  description String?
  clubId      String       @map("club_id")
  club        Club         @relation(fields: [clubId], references: [id], onDelete: Restrict)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  teamSeasons TeamSeason[]

  @@unique([clubId, name])
  @@map("teams")
}

enum StatusTeamSeason {
  DRAFT // por ejemplo para ofertas futuras
  ACTIVE
  FINISHED
  CANCELLED
}

model TeamSeason {
  id String @id @default(uuid())

  imageUrl    String? @map("image_url")
  description String?

  maxMembers Int @map("max_members")
  minMembers Int @map("min_members")

  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Restrict)

  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  seasonId String @map("season_id")
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Restrict)

  gender ProgramGender

  billingDay          Int              @map("billing_day") // 1 - 28
  registrationFee     Decimal          @map("registration_fee") @db.Decimal(10, 2)
  monthlyFee          Decimal          @map("monthly_fee") @db.Decimal(10, 2)
  debtToleranceMonths Int              @default(2) @map("debt_tolerance_months") // meses de tolerancia para no pagar
  lateFeeEnabled      Boolean          @default(false) @map("late_fee_enabled")
  lateFeePerDay       Decimal          @default(0) @map("late_fee_per_day") @db.Decimal(10, 2)
  graceDays           Int              @default(0) @map("grace_days")
  status              StatusTeamSeason @default(DRAFT)

  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  teamSeasonStaffs  TeamSeasonStaff[]
  paymentPlans      PaymentPlan[]
  playerMemberships PlayerMembership[]

  @@unique([teamId, categoryId, seasonId, gender])
  @@map("team_seasons")
}

// =================================
// FIN EQUIPOS
// =================================

// =================================
// JUGADORES Y MEMBRESIAS
// =================================

model Player {
  id                String             @id @default(uuid())
  personId          String             @unique
  person            Person             @relation(fields: [personId], references: [id])
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  playerMemberships PlayerMembership[]

  @@map("players")
}

enum PlayerMembershipStatus {
  ACTIVE // activo
  SUSPENDED // suspendido
  WITHDRAWN // retirado
  FINISHED // finalizado (por ejemplo al finalizar la temporada)
}

model PlayerMembership {
  id           String     @id @default(uuid())
  playerId     String     @map("player_id")
  player       Player     @relation(fields: [playerId], references: [id], onDelete: Restrict)
  teamSeasonId String     @map("team_season_id")
  teamSeason   TeamSeason @relation(fields: [teamSeasonId], references: [id], onDelete: Restrict)

  paymentPlanId String      @map("payment_plan_id")
  paymentPlan   PaymentPlan @relation(fields: [paymentPlanId], references: [id], onDelete: Restrict)

  startedAt DateTime  @map("started_at")
  endedAt   DateTime? @map("ended_at")

  status PlayerMembershipStatus @default(ACTIVE)

  notes String?

  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  membershipDiscounts MembershipDiscount[]

  @@map("player_membership")
}

enum MembershipDiscountType {
  SCHOLARSHIP // Beca
  SPECIAL_DISCOUNT // Descuento especial
  FINANCIAL_AID // Ayuda económica
  AGREEMENT // Convenio
  EXEMPTION // Exoneración
  OTHER // Otro
}

model PaymentPlan {
  id                          String     @id @default(uuid())
  teamSeasonId                String     @map("team_season_id")
  teamSeasons                 TeamSeason @relation(fields: [teamSeasonId], references: [id], onDelete: Restrict)
  name                        String
  registrationDiscountPercent Decimal    @map("registration_discount_percent") @db.Decimal(5, 2)
  monthlyDiscountPercent      Decimal    @map("monthly_discount_percent") @db.Decimal(5, 2)

  isDefault Boolean @default(false) // si es true, es el plan por defecto

  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  playerMemberships PlayerMembership[]

  @@map("payment_plans")
}

model MembershipDiscount {
  id                 String           @id @default(uuid())
  playerMembershipId String           @map("player_membership_id")
  playerMembership   PlayerMembership @relation(fields: [playerMembershipId], references: [id], onDelete: Restrict)

  monthlyDiscountPercent      Decimal @map("monthly_discount_percent") @db.Decimal(5, 2)
  registrationDiscountPercent Decimal @map("registration_discount_percent") @db.Decimal(5, 2)

  startDate DateTime  @map("start_date")
  endDate   DateTime? @map("end_date")

  type MembershipDiscountType

  reason String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("membership_discounts")
}

// =================================
// FIN JUGADORES Y MEMBRESIAS
// =================================

// =================================
// STAFF Y EQUIPOS
// =================================

model Staff {
  id               String            @id @default(uuid())
  personId         String            @unique @map("person_id")
  person           Person            @relation(fields: [personId], references: [id])
  isActive         Boolean           @default(true) @map("is_active")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  teamSeasonStaffs TeamSeasonStaff[]

  @@map("staff")
}

enum TeamSeasonStaffRole {
  HEAD_COACH
  ASSISTANT_COACH
  ASSISTANT
  VOLUNTEER
  DELEGATE
  OTHER
}

model TeamSeasonStaff {
  id String @id @default(uuid())

  teamSeasonId String @map("team_season_id")
  staffId      String @map("staff_id")

  role       TeamSeasonStaffRole
  // Si el rol es OTHER, se especifica en customRole
  customRole String?             @map("custom_role")

  startedAt DateTime  @map("started_at")
  endedAt   DateTime? @map("ended_at")

  // Si es el encargado del equipo
  isPrimary Boolean @default(false) @map("is_primary")

  notes String?

  teamSeason TeamSeason @relation(fields: [teamSeasonId], references: [id])
  staff      Staff      @relation(fields: [staffId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("team_season_staff")
}

// =================================
// FIN STAFF Y EQUIPOS
// =================================
